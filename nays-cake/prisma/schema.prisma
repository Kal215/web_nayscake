// ============================================================
// NAY'S CAKE - PRISMA SCHEMA
// Database Schema untuk Aplikasi Toko Kue Basah
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// USER - Tabel untuk autentikasi admin
// ============================================================
model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      UserRole @default(ADMIN)
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sales Sale[]

  @@map("users")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
}

// ============================================================
// SUPPLIER - Master data supplier kue
// ============================================================
model Supplier {
  id        String   @id @default(cuid())
  name      String   @unique
  phone     String?
  address   String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  products  Product[]
  saleItems SaleItem[]

  @@map("suppliers")
}

// ============================================================
// PRODUCT - Master data produk kue
// ============================================================
model Product {
  id           String   @id @default(cuid())
  supplierId   String
  name         String
  slug         String   @unique
  imageUrl     String?
  costPrice    Decimal  @db.Decimal(10, 2)  // Harga modal
  sellingPrice Decimal  @db.Decimal(10, 2)  // Harga jual
  description  String?
  category     String?                        // Kategori: Kue Basah, Bolu, Gorengan, dll
  unit         String   @default("pcs")       // Satuan: pcs, box, kg
  minStock     Int      @default(10)          // Minimal stok untuk alert
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  supplier     Supplier      @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  stockEntries StockEntry[]
  saleItems    SaleItem[]
  orderItems   OrderItem[]

  @@unique([supplierId, name]) // Pastikan kombinasi supplier+name unik
  @@map("products")
}

// ============================================================
// STOCK_ENTRY - Transaksi stok masuk harian
// ============================================================
model StockEntry {
  id         String   @id @default(cuid())
  productId  String
  date       DateTime @default(now())
  quantityIn Int                          // Jumlah barang masuk
  quantityRemaining Int?                 // Sisa (sore) — null = belum diisi
  notes      String?
  createdAt  DateTime @default(now())

  // Relations
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([date])
  @@map("stock_entries")
}

// ============================================================
// SALE - Header transaksi penjualan
// ============================================================
model Sale {
  id           String   @id @default(cuid())
  saleDate     DateTime @default(now())
  totalAmount  Decimal  @db.Decimal(12, 2)   // Total penjualan
  totalCost    Decimal  @db.Decimal(12, 2)   // Total modal
  totalProfit  Decimal  @db.Decimal(12, 2)   // Total keuntungan
  paymentMethod String?                       // cash, transfer, dll
  customerName String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  userId String?
  user   User?   @relation(fields: [userId], references: [id])
  items  SaleItem[]

  @@index([saleDate])
  @@map("sales")
}

// ============================================================
// SALE_ITEM - Detail item dalam transaksi penjualan
// ============================================================
model SaleItem {
  id        String   @id @default(cuid())
  saleId    String
  productId String
  supplierId String
  quantity  Int                          // Jumlah terjual
  price     Decimal  @db.Decimal(10, 2)  // Harga jual per unit (saat transaksi)
  cost      Decimal  @db.Decimal(10, 2)  // Modal per unit (saat transaksi)
  subtotal  Decimal  @db.Decimal(12, 2)  // quantity * price
  profit    Decimal  @db.Decimal(12, 2)  // (price - cost) * quantity
  createdAt DateTime @default(now())

  // Relations
  sale     Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id])

  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

// ============================================================
// SETTINGS - Pengaturan aplikasi
// ============================================================
model Settings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ============================================================
// ORDER - Pesanan masuk dari WhatsApp (belum tentu jadi penjualan)
// ============================================================
enum OrderStatus {
  MENUNGGU      // baru masuk dari bot
  DIKONFIRMASI  // mamah setujui
  SELESAI       // sudah diambil/dibayar
  DIBATALKAN
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique          // NAY-0001, dst
  customerPhone String?                       // nomor WA pelanggan
  customerName  String?
  totalAmount   Decimal     @db.Decimal(12, 2)
  status        OrderStatus @default(MENUNGGU)
  source        String      @default("whatsapp")
  notes         String?
  orderType     String?                      // "BELI" atau "PESANAN" (pre-order). null = lama/tak diketahui
  pickupAt      DateTime?                    // jadwal ambil (hasil AI parse tanggal), null bila tak ada/gagal
  pickupRaw     String?                      // teks tanggal asli dari pelanggan (cadangan, mis. "25 Des jam 10")
  pickupLocation String?                     // "UTAMA" (Cililin) | "CABANG" (Rancapanggung) | null
  notifiedAt    DateTime?                    // kapan admin dinotifikasi via WA; null = belum
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items OrderItem[]

  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id          String   @id @default(cuid())
  orderId     String
  productId   String
  productName String                          // simpan nama saat pesan (jaga histori)
  quantity    Int
  price       Decimal  @db.Decimal(10, 2)    // harga jual per unit saat pesan
  subtotal    Decimal  @db.Decimal(12, 2)    // quantity * price

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}
